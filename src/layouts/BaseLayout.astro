---
import '../styles/global.css';

const SITE_URL = 'https://futrio.pl';

type Props = {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
};

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage,
} = Astro.props;

const navigation = [
  { href: '/', label: 'Start' },
  { href: '/psy/', label: 'Psy' },
  { href: '/koty/', label: 'Koty' },
  { href: '/rasy/', label: 'Rasy' },
  { href: '/poradniki/', label: 'Poradniki' },
  { href: '/kalkulatory/', label: 'Kalkulatory' },
];

const footerMainLinks = [
  { href: '/', label: 'Start' },
  { href: '/psy/', label: 'Psy' },
  { href: '/koty/', label: 'Koty' },
  { href: '/rasy/', label: 'Rasy' },
  { href: '/poradniki/', label: 'Poradniki' },
  { href: '/kalkulatory/', label: 'Kalkulatory' },
];

const footerTopicLinks = [
  { href: '/koszty-utrzymania/', label: 'Koszty utrzymania' },
  { href: '/zywienie/', label: 'Żywienie' },
  { href: '/pielegnacja/', label: 'Pielęgnacja' },
  { href: '/poradniki/jak-wybrac-rase-psa/', label: 'Wybór rasy' },
  { href: '/poradniki/kalkulator-kalorii-dla-psa-i-kota/', label: 'Kalkulator kalorii' },
];

const footerTrustLinks = [
  { href: '/o-nas/', label: 'O nas' },
  { href: '/kontakt/', label: 'Kontakt' },
  { href: '/polityka-prywatnosci/', label: 'Polityka prywatności' },
  { href: '/polityka-cookies/', label: 'Polityka cookies' },
  { href: '/metodologia-ras/', label: 'Metodologia ras' },
  { href: '/informacja-o-afiliacji/', label: 'Informacja o afiliacji' },
];

function toAbsoluteUrl(url?: string): string | undefined {
  if (!url) {
    return undefined;
  }

  if (url.startsWith('http://') || url.startsWith('https://')) {
    return url;
  }

  return new URL(url, SITE_URL).toString();
}

const canonicalUrl = toAbsoluteUrl(canonical);
const ogImageUrl = toAbsoluteUrl(ogImage);
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#2f7d4f" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content="Futrio" />
    <meta property="og:locale" content="pl_PL" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/" aria-label="Futrio - strona główna">
          <img class="brand__logo" src="/brand/futrio-logo.svg" alt="Futrio" width="300" height="88" />
          <span class="brand__text">
            <span class="brand__claim">Przewodnik dla opiekunów zwierząt</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Główna nawigacja">
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__grid">
        <div class="site-footer__about">
          <a class="brand brand--footer" href="/" aria-label="Futrio - strona główna">
            <img class="brand__logo" src="/brand/futrio-logo.svg" alt="Futrio" width="300" height="88" />
          </a>
          <p>
            Futrio jest rozwijanym portalem informacyjnym o rasach, kosztach opieki,
            żywieniu i codziennych potrzebach zwierząt.
          </p>
          <p class="site-footer__disclaimer">
            Treści mają charakter informacyjny i nie zastępują konsultacji z lekarzem
            weterynarii. Niektóre linki mogą mieć w przyszłości charakter afiliacyjny.
          </p>
        </div>

        <nav class="site-footer__links" aria-label="Odkrywaj Futrio">
          <strong>Odkrywaj</strong>
          {footerMainLinks.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>

        <nav class="site-footer__links" aria-label="Tematy Futrio">
          <strong>Tematy</strong>
          {footerTopicLinks.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>

        <nav class="site-footer__links" aria-label="Informacje i dokumenty">
          <strong>Informacje</strong>
          {footerTrustLinks.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </footer>
  </body>
</html>
