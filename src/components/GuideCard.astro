---
import type { Guide } from '../data/guides';

type Props = {
  guide: Guide;
  variant?: 'compact' | 'featured';
};

const { guide, variant = 'compact' } = Astro.props;
---

<article class:list={['guide-card', `guide-card--${variant}`]}>
  <div class="guide-card__icon" aria-hidden="true">
    {guide.categoryLabel.slice(0, 1)}
  </div>
  <div class="guide-card__content">
    <span class="badge">{guide.categoryLabel}</span>
    <h3>
      <a href={`/poradniki/${guide.slug}/`}>{guide.title}</a>
    </h3>
    <p>{guide.description}</p>
    <div class="guide-card__meta">
      <span>{guide.readingTime}</span>
      <span>Aktualizacja: {guide.updatedAt}</span>
    </div>
    <a class="guide-card__cta" href={`/poradniki/${guide.slug}/`}>Czytaj poradnik</a>
  </div>
</article>
