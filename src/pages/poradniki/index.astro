---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getAllGuides,
  getFeaturedGuides,
  getGuidesByCategory,
  type GuideCategory,
} from '../../data/guides';

const guideCategories: { category: GuideCategory; label: string; description: string }[] = [
  {
    category: 'psy',
    label: 'Psy',
    description: 'Wybór psa, potrzeby ras, rodzina, aktywność i codzienna opieka.',
  },
  {
    category: 'koty',
    label: 'Koty',
    description: 'Mieszkanie z kotem, przygotowanie domu, temperament i bezpieczeństwo.',
  },
  {
    category: 'zywienie',
    label: 'Żywienie',
    description: 'Podstawy karmienia, kalorie, porcje i rozsądne korzystanie z kalkulatorów.',
  },
  {
    category: 'koszty',
    label: 'Koszty',
    description: 'Budżet na karmę, weterynarza, pielęgnację, wyprawkę i rezerwy.',
  },
  {
    category: 'pielegnacja',
    label: 'Pielęgnacja',
    description: 'Sierść, pazury, zęby, uszy, kuweta, groomer i spokojna rutyna.',
  },
  {
    category: 'zdrowie',
    label: 'Zdrowie',
    description: 'Profilaktyka i budżet weterynaryjny bez diagnozowania przez internet.',
  },
  {
    category: 'wyprawka',
    label: 'Wyprawka',
    description: 'Co kupić na start dla psa lub kota, a z czym spokojnie poczekać.',
  },
  {
    category: 'wybor-rasy',
    label: 'Wybór rasy',
    description: 'Jak dopasować rasę do mieszkania, czasu, doświadczenia i rodziny.',
  },
];

const guides = getAllGuides();
const featuredGuides = getFeaturedGuides(4);
---

<BaseLayout
  title="Poradniki dla opiekunów zwierząt | Futrio"
  description="Praktyczne poradniki Futrio o rasach psów i kotów, kosztach utrzymania, żywieniu, pielęgnacji, wyprawce i wyborze zwierzęcia."
  canonical="/poradniki/"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Poradniki Futrio</p>
      <h1>Poradniki dla opiekunów zwierząt</h1>
      <p class="lead">
        Ten dział pomaga w żywieniu, kosztach, pielęgnacji, wyborze rasy i przygotowaniu
        domu na psa lub kota. Każdy poradnik jest pisany praktycznie: z przykładami,
        ostrzeżeniami i bez obiecywania prostych odpowiedzi tam, gdzie ich nie ma.
      </p>
      <div class="actions">
        <a class="button" href="/rasy/">Zacznij od katalogu ras</a>
        <a class="button button--secondary" href="/kalkulatory/">Sprawdź kalkulatory</a>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Od czego zacząć?</p>
        <h2>Najważniejsze poradniki na start</h2>
      </div>
      <div class="guide-grid guide-grid--featured">
        {
          featuredGuides.map((guide) => (
            <article class="guide-card guide-card--highlight">
              <span class="badge">{guide.categoryLabel}</span>
              <h3>{guide.title}</h3>
              <p>{guide.description}</p>
              <a class="text-link" href={`/poradniki/${guide.slug}/`}>
                Czytaj poradnik
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Kategorie</p>
        <h2>Wybierz temat</h2>
      </div>
      <div class="topic-grid">
        {
          guideCategories.map((item) => {
            const categoryGuides = getGuidesByCategory(item.category);

            return (
              <article class="topic-card">
                <span class="badge">{categoryGuides.length} poradnik(i)</span>
                <h3>{item.label}</h3>
                <p>{item.description}</p>
                {categoryGuides[0] && (
                  <a class="text-link" href={`/poradniki/${categoryGuides[0].slug}/`}>
                    Zobacz pierwszy poradnik
                  </a>
                )}
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Biblioteka</p>
          <h2>Wszystkie poradniki</h2>
        </div>
        <span class="badge">{guides.length} poradników</span>
      </div>
      <div class="guide-grid">
        {
          guides.map((guide) => (
            <article class="guide-card">
              <div>
                <span class="badge">{guide.categoryLabel}</span>
                <h3>{guide.title}</h3>
              </div>
              <p>{guide.description}</p>
              <div class="guide-card__meta">
                <span>{guide.readingTime}</span>
                <span>Aktualizacja: {guide.updatedAt}</span>
              </div>
              <a class="button button--secondary" href={`/poradniki/${guide.slug}/`}>
                Czytaj poradnik
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
