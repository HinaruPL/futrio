---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedGuides } from '../data/guides';
import {
  formatActivityLevel,
  formatRange,
  formatSpecies,
  getAllBreeds,
} from '../lib/breeds-data';

const popularBreeds = getAllBreeds().slice(0, 6);
const featuredGuides = getFeaturedGuides(6);
---

<BaseLayout
  title="Futrio - praktyczna baza wiedzy o zwierzętach"
  description="Futrio pomaga poznawać rasy psów i kotów, sprawdzać koszty utrzymania, żywienie, aktywność i korzystać z prostych kalkulatorów dla opiekunów."
  canonical="/"
>
  <section class="hero hero--home">
    <div class="container hero__content">
      <p class="eyebrow">Portal zoologiczny</p>
      <h1>Futrio - praktyczna baza wiedzy o zwierzętach</h1>
      <p class="lead">
        Porównuj rasy psów i kotów, planuj koszty utrzymania, sprawdzaj podstawy
        żywienia i pielęgnacji oraz korzystaj z kalkulatorów jako punktu wyjścia do
        mądrej opieki.
      </p>
      <div class="actions">
        <a class="button" href="/rasy/">Przeglądaj rasy</a>
        <a class="button button--secondary" href="/poradniki/">Czytaj poradniki</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Szybki wybór</p>
        <h2>Od czego chcesz zacząć?</h2>
      </div>
      <div class="topic-grid">
        <article class="topic-card topic-card--large">
          <span class="badge">psy</span>
          <h3>Dla opiekunów psów</h3>
          <p>
            Rasy psów, wybór psa do stylu życia, koszty, aktywność, żywienie i wyprawka
            dla przyszłych oraz obecnych opiekunów.
          </p>
          <a class="text-link" href="/psy/">Przejdź do sekcji Psy</a>
        </article>
        <article class="topic-card topic-card--large">
          <span class="badge">koty</span>
          <h3>Dla opiekunów kotów</h3>
          <p>
            Rasy kotów, przygotowanie mieszkania, kuweta, drapak, żywienie, pielęgnacja
            i koszty codziennej opieki.
          </p>
          <a class="text-link" href="/koty/">Przejdź do sekcji Koty</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Start od rasy</p>
          <h2>Popularne rasy</h2>
        </div>
        <a class="text-link" href="/rasy/">Zobacz cały katalog</a>
      </div>
      <div class="breed-grid grid">
        {
          popularBreeds.map((breed) => (
            <article class="card breed-card">
              <span class="badge">{formatSpecies(breed.species)}</span>
              <h3>{breed.name}</h3>
              <p>{breed.short_description ?? 'Opis rasy jest w przygotowaniu.'}</p>
              <div class="breed-card__meta">
                <span>Waga: {formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')}</span>
                <span>Aktywność: {formatActivityLevel(breed.activity_level)}</span>
              </div>
              <a class="breed-card__link" href={`/rasy/${breed.slug}/`}>
                Zobacz opis rasy
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Evergreen</p>
          <h2>Najważniejsze poradniki</h2>
        </div>
        <a class="text-link" href="/poradniki/">Wszystkie poradniki</a>
      </div>
      <div class="guide-grid">
        {
          featuredGuides.map((guide) => (
            <article class="guide-card">
              <span class="badge">{guide.categoryLabel}</span>
              <h3>{guide.title}</h3>
              <p>{guide.description}</p>
              <a class="text-link" href={`/poradniki/${guide.slug}/`}>Czytaj poradnik</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Najczęściej sprawdzane tematy</p>
        <h2>Praktyczne huby Futrio</h2>
      </div>
      <div class="topic-grid">
        <a class="topic-card topic-card--link" href="/koszty-utrzymania/">
          <span>Koszty</span>
          <strong>Koszty utrzymania psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/zywienie/">
          <span>Żywienie</span>
          <strong>Żywienie psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/pielegnacja/">
          <span>Pielęgnacja</span>
          <strong>Pielęgnacja psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/kalkulatory/">
          <span>Narzędzia</span>
          <strong>Kalkulatory Futrio</strong>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <h2>Ważna informacja</h2>
        <p>
          Futrio nie zastępuje lekarza weterynarii. Informacje mają charakter
          orientacyjny i pomagają przygotować się do rozmowy ze specjalistą lub
          świadomej opieki nad zwierzęciem.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
