---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreedCard from '../components/BreedCard.astro';
import GuideCard from '../components/GuideCard.astro';
import { getFeaturedGuides } from '../data/guides';
import { getAllBreeds, getBreedBySlug, getBreedPhotoUrl } from '../lib/breeds-data';

const popularBreeds = getAllBreeds().slice(0, 6);
const featuredGuides = getFeaturedGuides(4);
const heroBreeds = ['labrador-retriever', 'ragdoll', 'border-collie']
  .map((slug) => getBreedBySlug(slug))
  .filter(Boolean);
---

<BaseLayout
  title="Futrio - praktyczna baza wiedzy o zwierzętach"
  description="Futrio pomaga poznawać rasy psów i kotów, sprawdzać koszty utrzymania, żywienie, aktywność i korzystać z prostych kalkulatorów dla opiekunów."
  canonical="/"
>
  <section class="hero hero--home">
    <div class="container hero-split">
      <div class="hero__content">
        <p class="eyebrow">Portal dla opiekunów psów i kotów</p>
        <h1>Poznaj rasy, koszty i potrzeby swojego przyszłego pupila</h1>
        <p class="lead">
          Futrio pomaga szybko porównać rasy, oszacować budżet i wejść w praktyczne
          poradniki bez przekopywania ściany tekstu.
        </p>
        <div class="actions">
          <a class="button" href="/rasy/">Przeglądaj rasy</a>
          <a class="button button--secondary" href="/poradniki/">Sprawdź poradniki</a>
        </div>
      </div>

      <aside class="home-visual" aria-label="Przykładowe rasy w Futrio">
        <div class="home-visual__orb" aria-hidden="true"></div>
        {
          heroBreeds.map((breed, index) => (
            breed && (
              <a class:list={['home-visual-card', `home-visual-card--${index + 1}`]} href={`/rasy/${breed.slug}/`}>
                {
                  getBreedPhotoUrl(breed) ? (
                    <img
                      src={getBreedPhotoUrl(breed) ?? ''}
                      alt={`${breed.species === 'cat' ? 'Ilustracja kota' : 'Ilustracja rasy'} ${breed.name}`}
                      width="1200"
                      height="800"
                    />
                  ) : (
                    <div class="home-visual-card__placeholder" aria-hidden="true"></div>
                  )
                }
                <span>{breed.name}</span>
              </a>
            )
          ))
        }
      </aside>
    </div>
    <div class="container">
      <div class="hero-stats-panel" aria-label="Najważniejsze informacje o Futrio">
        <div><strong>30</strong><span>ras</span></div>
        <div><strong>16</strong><span>poradników</span></div>
        <div><strong>2</strong><span>kalkulatory</span></div>
        <div><strong>5</strong><span>głównych tematów</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Szybki wybór</p>
        <h2>Od czego chcesz zacząć?</h2>
      </div>
      <div class="topic-grid">
        <article class="topic-card topic-card--large">
          <span class="topic-card__symbol">01</span>
          <h3>Wybieram rasę</h3>
          <p>Porównaj temperament, wagę, aktywność i pielęgnację.</p>
          <a class="text-link" href="/rasy/">Przejdź do katalogu</a>
        </article>
        <article class="topic-card topic-card--large">
          <span class="topic-card__symbol">02</span>
          <h3>Mam psa</h3>
          <p>Sprawdź poradniki o wyborze, żywieniu, ruchu i kosztach.</p>
          <a class="text-link" href="/psy/">Przejdź do sekcji Psy</a>
        </article>
        <article class="topic-card topic-card--large">
          <span class="topic-card__symbol">03</span>
          <h3>Mam kota</h3>
          <p>Zobacz rasy kotów, wyprawkę, pielęgnację i domową rutynę.</p>
          <a class="text-link" href="/koty/">Przejdź do sekcji Koty</a>
        </article>
        <article class="topic-card topic-card--large">
          <span class="topic-card__symbol">04</span>
          <h3>Planuję koszty</h3>
          <p>Ułóż realistyczny budżet na karmę, profilaktykę i akcesoria.</p>
          <a class="text-link" href="/koszty-utrzymania/">Sprawdź koszty</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Start od rasy</p>
          <h2>Popularne rasy</h2>
        </div>
        <a class="text-link" href="/rasy/">Zobacz cały katalog</a>
      </div>
      <div class="breed-grid grid">
        {
          popularBreeds.map((breed) => (
            <BreedCard breed={breed} variant="compact" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Evergreen</p>
          <h2>Najważniejsze poradniki</h2>
        </div>
        <a class="text-link" href="/poradniki/">Wszystkie poradniki</a>
      </div>
      <div class="guide-grid">
        {
          featuredGuides.map((guide) => (
            <GuideCard guide={guide} variant="featured" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">Narzędzia</p>
          <h2>Kalkulatory Futrio</h2>
        </div>
        <a class="text-link" href="/kalkulatory/">Przejdź do kalkulatorów</a>
      </div>
      <div class="grid grid--2">
        <article class="feature-card">
          <span class="badge">Kalorie</span>
          <h3>Kalkulator kalorii</h3>
          <p>
            Pomaga orientacyjnie oszacować dzienne zapotrzebowanie energetyczne psa
            lub kota w kontekście konkretnej rasy.
          </p>
          <a class="button button--secondary" href="/kalkulatory/">Sprawdź narzędzie</a>
        </article>
        <article class="feature-card">
          <span class="badge">Budżet</span>
          <h3>Kalkulator kosztów utrzymania</h3>
          <p>
            Ułatwia zaplanowanie miesięcznych i rocznych wydatków na karmę,
            pielęgnację, profilaktykę oraz akcesoria.
          </p>
          <a class="button button--secondary" href="/rasy/">Wybierz rasę</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Najczęściej sprawdzane tematy</p>
        <h2>Praktyczne huby Futrio</h2>
      </div>
      <div class="topic-grid">
        <a class="topic-card topic-card--link" href="/koszty-utrzymania/">
          <span>Koszty</span>
          <strong>Koszty utrzymania psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/zywienie/">
          <span>Żywienie</span>
          <strong>Żywienie psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/pielegnacja/">
          <span>Pielęgnacja</span>
          <strong>Pielęgnacja psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/kalkulatory/">
          <span>Narzędzia</span>
          <strong>Kalkulatory Futrio</strong>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <h2>Ważna informacja</h2>
        <p>
          Futrio nie zastępuje lekarza weterynarii. Informacje mają charakter
          orientacyjny i pomagają przygotować się do rozmowy ze specjalistą lub
          świadomej opieki nad zwierzęciem.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
