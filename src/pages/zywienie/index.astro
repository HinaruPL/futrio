---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuideBySlug } from '../../data/guides';
import { getAllBreeds } from '../../lib/breeds-data';

const guideSlugs = [
  'jak-karmic-psa-podstawy',
  'jak-karmic-kota-podstawy',
  'kalkulator-kalorii-dla-psa-i-kota',
];
const guides = guideSlugs.map((slug) => getGuideBySlug(slug)).filter(Boolean);
const nutritionBreedSlugs = [
  'labrador-retriever',
  'kot-brytyjski-krotkowlosy',
  'maine-coon',
  'buldog-francuski',
];
const nutritionBreeds = getAllBreeds().filter((breed) => nutritionBreedSlugs.includes(breed.slug));
---

<BaseLayout
  title="Żywienie psa i kota - podstawy, kalorie i praktyczne wskazówki | Futrio"
  description="Poznaj podstawy żywienia psów i kotów, sprawdź, co wpływa na zapotrzebowanie kaloryczne i jak korzystać z kalkulatora kalorii Futrio."
  canonical="/zywienie/"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Żywienie</p>
      <h1>Żywienie psa i kota</h1>
      <p class="lead">
        Żywienie warto planować według gatunku, wieku, aktywności, masy ciała i zdrowia.
        Kalkulatory pomagają zacząć, ale nie zastępują obserwacji zwierzęcia ani
        konsultacji z lekarzem weterynarii przy problemach zdrowotnych.
      </p>
      <div class="actions">
        <a class="button" href="/kalkulatory/">Sprawdź kalkulator kalorii</a>
        <a class="button button--secondary" href="/poradniki/kalkulator-kalorii-dla-psa-i-kota/">Jak rozumieć wynik?</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="topic-grid">
        <article class="topic-card">
          <h2>Od czego zależy porcja karmy?</h2>
          <p>Od gatunku, wieku, aktywności, masy ciała, kastracji, zdrowia i kaloryczności konkretnej karmy.</p>
        </article>
        <article class="topic-card">
          <h2>Dlaczego kalkulator kalorii jest tylko punktem wyjścia?</h2>
          <p>Bo nie zna pełnej historii zwierzęcia. Wynik trzeba połączyć z obserwacją sylwetki i energii.</p>
        </article>
        <article class="topic-card">
          <h2>Pies i kot mają różne potrzeby</h2>
          <p>Kot jest mięsożercą o innych wymaganiach niż pies. Nie warto przenosić zasad jeden do jednego.</p>
        </article>
        <article class="topic-card">
          <h2>Kontrola masy ciała</h2>
          <p>Regularne ważenie i ocena sylwetki pomagają szybciej zauważyć nadwagę albo niedowagę.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Poradniki żywieniowe</p>
        <h2>Praktyczne podstawy</h2>
      </div>
      <div class="guide-grid">
        {
          guides.map((guide) => (
            guide && (
              <article class="guide-card">
                <span class="badge">{guide.categoryLabel}</span>
                <h3>{guide.title}</h3>
                <p>{guide.description}</p>
                <a class="text-link" href={`/poradniki/${guide.slug}/`}>Czytaj poradnik</a>
              </article>
            )
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Rasy</p>
        <h2>Rasy, przy których żywienie jest ważnym tematem</h2>
      </div>
      <div class="related-breeds__grid">
        {
          nutritionBreeds.map((breed) => (
            <a href={`/rasy/${breed.slug}/`}>
              <span>{breed.species === 'dog' ? 'pies' : 'kot'}</span>
              <strong>{breed.name}</strong>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
