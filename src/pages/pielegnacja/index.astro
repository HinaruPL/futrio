---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreedCard from '../../components/BreedCard.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getGuideBySlug } from '../../data/guides';
import { getAllBreeds } from '../../lib/breeds-data';

const guideSlugs = [
  'pielegnacja-psa',
  'pielegnacja-kota',
  'wyprawka-dla-psa',
  'wyprawka-dla-kota',
];
const guides = guideSlugs.map((slug) => getGuideBySlug(slug)).filter(Boolean);
const groomingBreedSlugs = [
  'golden-retriever',
  'shih-tzu',
  'maltanczyk',
  'yorkshire-terrier',
  'maine-coon',
  'kot-perski',
];
const groomingBreeds = getAllBreeds().filter((breed) => groomingBreedSlugs.includes(breed.slug));
---

<BaseLayout
  title="Pielęgnacja psa i kota - sierść, pazury, uszy i codzienna rutyna | Futrio"
  description="Sprawdź podstawy pielęgnacji psa i kota: sierść, czesanie, pazury, uszy, zęby, groomer i koszty pielęgnacji."
  canonical="/pielegnacja/"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Pielęgnacja</p>
      <h1>Pielęgnacja psa i kota</h1>
      <p class="lead">
        Pielęgnacja to codzienna rutyna, która pomaga utrzymać komfort zwierzęcia i
        szybciej zauważyć problemy. Zakres zależy od gatunku, rasy, sierści, wieku i
        temperamentu.
      </p>
      <div class="actions">
        <a class="button" href="/poradniki/pielegnacja-psa/">Pielęgnacja psa</a>
        <a class="button button--secondary" href="/poradniki/pielegnacja-kota/">Pielęgnacja kota</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="topic-grid">
        <article class="topic-card">
          <h2>Sierść i regularne czesanie</h2>
          <p>Typ sierści decyduje o narzędziach, częstotliwości czesania i ryzyku kołtunów.</p>
        </article>
        <article class="topic-card">
          <h2>Pazury, uszy i zęby</h2>
          <p>Te elementy łatwo pominąć, a często jako pierwsze pokazują dyskomfort lub zaniedbania.</p>
        </article>
        <article class="topic-card">
          <h2>Kiedy potrzebny jest groomer?</h2>
          <p>Przy strzyżeniu, trymowaniu, trudnych kołtunach i rasach wymagających fachowej pielęgnacji.</p>
        </article>
        <article class="topic-card">
          <h2>Pielęgnacja a koszty utrzymania</h2>
          <p>Regularny groomer, kosmetyki i narzędzia warto uwzględnić w miesięcznym budżecie.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Poradniki</p>
        <h2>Spokojna rutyna pielęgnacji</h2>
      </div>
      <div class="guide-grid">
        {
          guides.map((guide) => (
            guide && (
              <GuideCard guide={guide} />
            )
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Rasy</p>
        <h2>Rasy wymagające większej pielęgnacji</h2>
      </div>
      <div class="breed-grid breed-grid--related">
        {
          groomingBreeds.map((breed) => (
            <BreedCard breed={breed} variant="related" />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
