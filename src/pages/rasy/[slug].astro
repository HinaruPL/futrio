---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalorieCalculator from '../../components/CalorieCalculator';
import CostCalculator from '../../components/CostCalculator';
import {
  type Breed,
  type BreedContentSection,
  formatActivityLevel,
  formatGroomingLevel,
  formatRange,
  formatScore,
  formatSpecies,
  formatTrainingDifficulty,
  getBreedStaticPaths,
  getOtherBreeds,
} from '../../lib/breeds-data';

export function getStaticPaths() {
  return getBreedStaticPaths();
}

type Props = {
  breed: Breed;
};

const { breed } = Astro.props;
const title =
  breed.meta_title ?? `${breed.name} - opis rasy, charakter i koszty utrzymania | Futrio`;
const description =
  breed.meta_description ??
  breed.short_description ??
  `Sprawdź opis rasy ${breed.name}: charakter, waga, aktywność, żywienie, zdrowie i orientacyjne koszty utrzymania.`;
const h1 = breed.h1 ?? breed.name;
const calories = formatRange(
  breed.daily_calories_min,
  breed.daily_calories_max,
  'kcal'
);
const sections = [...breed.contentSections].sort(
  (first, second) => first.sort_order - second.sort_order
);
const relatedBreeds = getOtherBreeds(breed.slug, 3);
const affiliateLinks = breed.affiliateLinks.filter((link) => link.is_active === 1);
const primaryAffiliateLink = affiliateLinks[0] ?? null;
const defaultWeightKg =
  breed.weight_min_kg !== null && breed.weight_max_kg !== null
    ? Number(((breed.weight_min_kg + breed.weight_max_kg) / 2).toFixed(1))
    : breed.weight_min_kg ?? breed.weight_max_kg ?? null;
const imageUrl = breed.image?.image_url ?? '';
const hasRealImage =
  Boolean(breed.image) &&
  breed.image?.image_source_type !== 'placeholder' &&
  (imageUrl.startsWith('https://') ||
    imageUrl.startsWith('http://') ||
    imageUrl.startsWith('/'));

const heroStats = [
  ['Waga', formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')],
  ['Wysokość', formatRange(breed.height_min_cm, breed.height_max_cm, 'cm')],
  [
    'Długość życia',
    formatRange(
      breed.life_expectancy_min_years,
      breed.life_expectancy_max_years,
      'lat'
    ),
  ],
  ['Aktywność', formatActivityLevel(breed.activity_level)],
  ['Pielęgnacja', formatGroomingLevel(breed.grooming_level)],
  ['Szkolenie', formatTrainingDifficulty(breed.training_difficulty)],
];

const details = [
  ['Gatunek', formatSpecies(breed.species)],
  ['Waga', formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')],
  ['Wysokość', formatRange(breed.height_min_cm, breed.height_max_cm, 'cm')],
  [
    'Długość życia',
    formatRange(
      breed.life_expectancy_min_years,
      breed.life_expectancy_max_years,
      'lat'
    ),
  ],
  ['Aktywność', formatActivityLevel(breed.activity_level)],
  ['Pielęgnacja', formatGroomingLevel(breed.grooming_level)],
  ['Trudność szkolenia', formatTrainingDifficulty(breed.training_difficulty)],
  ['Dla rodziny', formatScore(breed.family_friendly_score)],
  ['Do mieszkania', formatScore(breed.apartment_score)],
  ['Dzienne kalorie', calories],
];

function getParagraphs(section: BreedContentSection): string[] {
  if (section.section_key === 'faq') {
    return section.body
      .split(/(?=Czy )/)
      .map((item) => item.trim())
      .filter(Boolean);
  }

  return section.body
    .split(/\r?\n+/)
    .map((paragraph) => paragraph.trim())
    .filter(Boolean);
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/rasy/${breed.slug}/`}
  ogType="article"
>
  <section class="breed-hero">
    <div class="container breed-hero__grid">
      <div class="breed-hero__content">
        <nav class="breadcrumbs" aria-label="Okruszki">
          <a href="/">Futrio</a> &gt; <a href="/rasy/">Rasy</a> &gt; {breed.name}
        </nav>
        <span class="badge">{formatSpecies(breed.species)}</span>
        <h1>{h1}</h1>
        <p class="lead">{breed.short_description ?? 'Opis rasy jest w przygotowaniu.'}</p>

        <dl class="hero-stats">
          {
            heroStats.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <aside class="breed-media" aria-label="Zdjęcie rasy">
        {
          hasRealImage && breed.image ? (
            <figure class="breed-image">
              <img
                src={breed.image.image_url}
                alt={breed.image.image_alt}
                title={breed.image.image_title ?? breed.name}
                loading="eager"
              />
              {breed.image.image_credit && (
                <figcaption>{breed.image.image_credit}</figcaption>
              )}
            </figure>
          ) : (
            <div class="breed-image-placeholder">
              <strong>Zdjęcie rasy wkrótce</strong>
              <p>Tu dodamy bezpieczną grafikę lub zdjęcie z prawami do użycia.</p>
            </div>
          )
        }
      </aside>
    </div>
  </section>

  <!-- TODO: Google AdSense placement - after hero -->

  <section class="section">
    <div class="container article-layout">
      <aside class="toc" aria-label="Spis treści">
        <h2>Spis treści</h2>
        <nav>
          <a href="#najwazniejsze-informacje">Najważniejsze informacje</a>
          <a href="#narzedzia-dla-opiekuna">Narzędzia dla opiekuna</a>
          {
            sections.map((section) => (
              <a href={`#${section.section_key}`}>{section.heading}</a>
            ))
          }
        </nav>
      </aside>

      <article class="breed-article">
        <section id="najwazniejsze-informacje" class="article-section">
          <h2>Najważniejsze informacje</h2>
          <dl class="info-grid info-grid--article">
            {
              details.map(([label, value]) => (
                <div class="info-item">
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))
            }
          </dl>
        </section>

        <section class="tools-section" id="narzedzia-dla-opiekuna">
          <div class="tool-intro">
            <p class="eyebrow">Praktyczne narzędzia</p>
            <h2>Narzędzia dla opiekuna</h2>
            <p>
              Skorzystaj z prostych kalkulatorów Futrio, aby oszacować dzienne
              zapotrzebowanie kaloryczne oraz orientacyjne koszty utrzymania tej
              rasy. Wyniki mają charakter poglądowy i warto traktować je jako
              punkt wyjścia do dalszego planowania.
            </p>
          </div>

          <div class="tools-grid">
            <article class="tool-card" id="kalkulator-kalorii">
              <div class="tool-card__header">
                <h3>Kalkulator kalorii</h3>
                <p>Do oszacowania dziennego zapotrzebowania energetycznego.</p>
              </div>
              <CalorieCalculator
                breedName={breed.name}
                species={breed.species}
                defaultWeightKg={defaultWeightKg}
                dailyCaloriesMin={breed.daily_calories_min}
                dailyCaloriesMax={breed.daily_calories_max}
                affiliateCtaLabel={
                  primaryAffiliateLink?.button_label ?? primaryAffiliateLink?.anchor_text
                }
                affiliateCtaUrl={primaryAffiliateLink?.url}
                affiliateDisclosure={primaryAffiliateLink?.disclosure}
                client:visible
              />
            </article>

            <article class="tool-card" id="kalkulator-kosztow">
              <div class="tool-card__header">
                <h3>Kalkulator kosztów utrzymania</h3>
                <p>Do oszacowania miesięcznych i rocznych wydatków.</p>
              </div>
              <CostCalculator
                breedName={breed.name}
                species={breed.species}
                weightMinKg={breed.weight_min_kg}
                weightMaxKg={breed.weight_max_kg}
                groomingLevel={breed.grooming_level}
                affiliateCtaLabel={
                  primaryAffiliateLink?.button_label ?? primaryAffiliateLink?.anchor_text
                }
                affiliateCtaUrl={primaryAffiliateLink?.url}
                affiliateDisclosure={primaryAffiliateLink?.disclosure}
                client:visible
              />
            </article>
          </div>
        </section>

        {
          sections.map((section) => (
            <>
              {section.section_key === 'faq' && (
                <!-- TODO: Google AdSense placement - before FAQ -->
              )}

              <section
                id={section.section_key}
                class:list={[
                  'article-section',
                  section.section_key === 'faq' && 'faq-section',
                ]}
              >
                <h2>{section.heading}</h2>

                {getParagraphs(section).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.section_key === 'health' && (
                  <div class="health-disclaimer">
                    Informacje zdrowotne mają charakter orientacyjny i nie zastępują
                    konsultacji z lekarzem weterynarii.
                  </div>
                )}
              </section>

              {section.section_key === 'feeding' && (
                <>
                  <section class="affiliate-placeholder">
                    <h2>Polecane produkty dla tej rasy</h2>
                    {affiliateLinks.length > 0 ? (
                      <div class="affiliate-card-grid">
                        {affiliateLinks.map((link) => (
                          <article class="affiliate-card">
                            <h3>{link.anchor_text ?? link.label}</h3>
                            <p>
                              {link.description ??
                                'W przyszłości pokażemy tu produkty dopasowane do potrzeb tej rasy.'}
                            </p>
                            {link.url.includes('example.com') && (
                              <p class="affiliate-note">
                                Przykładowy placeholder - link zostanie podmieniony po wyborze programu afiliacyjnego.
                              </p>
                            )}
                            {link.disclosure && (
                              <p class="affiliate-disclosure">{link.disclosure}</p>
                            )}
                            <a class="button button--secondary" href={link.url} rel="nofollow sponsored">
                              {link.button_label ?? 'Zobacz polecane produkty'}
                            </a>
                          </article>
                        ))}
                      </div>
                    ) : (
                      <p>
                        W przyszłości pokażemy tu karmy, akcesoria i produkty dopasowane
                        do potrzeb tej rasy. Linki będą oznaczone jako afiliacyjne, jeśli
                        będą prowadzić do programu partnerskiego.
                      </p>
                    )}
                    <!-- TODO: Affiliate CTA based on D1 affiliate_links -->
                  </section>

                  <!-- TODO: Google AdSense placement - mid article -->
                </>
              )}
            </>
          ))
        }

        <section class="related-breeds">
          <h2>Zobacz też inne rasy</h2>
          <div class="related-breeds__grid">
            {
              relatedBreeds.map((relatedBreed) => (
                <a href={`/rasy/${relatedBreed.slug}/`}>
                  <span>{formatSpecies(relatedBreed.species)}</span>
                  <strong>{relatedBreed.name}</strong>
                </a>
              ))
            }
          </div>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>
