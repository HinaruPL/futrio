---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreedCard from '../../components/BreedCard.astro';
import CalorieCalculator from '../../components/CalorieCalculator';
import CostCalculator from '../../components/CostCalculator';
import GuideCard from '../../components/GuideCard.astro';
import { getGuideBySlug } from '../../data/guides';
import {
  type Breed,
  type BreedContentSection,
  formatActivityLevel,
  formatGroomingLevel,
  formatRange,
  formatScore,
  formatSpecies,
  formatTrainingDifficulty,
  getBreedFaqs,
  getBreedStaticPaths,
  getBreedRecognitionStatus,
  getVisibleContentSections,
  getBreedPhotoUrl,
  getOtherBreeds,
} from '../../lib/breeds-data';

export function getStaticPaths() {
  return getBreedStaticPaths();
}

type Props = {
  breed: Breed;
};

const { breed } = Astro.props;
const title =
  breed.meta_title ?? `${breed.name} - opis rasy, charakter i koszty utrzymania | Futrio`;
const description =
  breed.meta_description ??
  breed.short_description ??
  `Sprawdź opis rasy ${breed.name}: charakter, waga, aktywność, żywienie, zdrowie i orientacyjne koszty utrzymania.`;
const h1 = breed.h1 ?? breed.name;
const calories = formatRange(
  breed.daily_calories_min,
  breed.daily_calories_max,
  'kcal'
);
const sections = getVisibleContentSections(breed);
const faqs = getBreedFaqs(breed);
const recognitionStatus = getBreedRecognitionStatus(breed);
const allRecognitionsNeedVerification = recognitionStatus === 'needs_verification';
const relatedBreeds = getOtherBreeds(breed.slug, 3);
const affiliateLinks = breed.affiliateLinks.filter((link) => link.is_active === 1);
const primaryAffiliateLink = affiliateLinks[0] ?? null;
const usefulGuideSlugs =
  breed.species === 'cat'
    ? ['kot-do-mieszkania', 'jak-karmic-kota-podstawy', 'pielegnacja-kota']
    : ['jak-wybrac-rase-psa', 'jak-karmic-psa-podstawy', 'ile-kosztuje-utrzymanie-psa'];
const usefulGuides = usefulGuideSlugs.map((slug) => getGuideBySlug(slug)).filter(Boolean);
const speciesHub =
  breed.species === 'cat'
    ? { href: '/koty/', label: 'Koty - hub Futrio' }
    : { href: '/psy/', label: 'Psy - hub Futrio' };
const defaultWeightKg =
  breed.weight_min_kg !== null && breed.weight_max_kg !== null
    ? Number(((breed.weight_min_kg + breed.weight_max_kg) / 2).toFixed(1))
    : breed.weight_min_kg ?? breed.weight_max_kg ?? null;
const calculatorWeightKg = defaultWeightKg ?? undefined;
const calculatorDailyCaloriesMin = breed.daily_calories_min ?? undefined;
const calculatorDailyCaloriesMax = breed.daily_calories_max ?? undefined;
const calculatorWeightMinKg = breed.weight_min_kg ?? undefined;
const calculatorWeightMaxKg = breed.weight_max_kg ?? undefined;
const calculatorGroomingLevel = breed.grooming_level ?? undefined;
const affiliateCtaLabel =
  primaryAffiliateLink?.button_label ?? primaryAffiliateLink?.anchor_text ?? undefined;
const affiliateCtaUrl = primaryAffiliateLink?.url ?? undefined;
const affiliateDisclosure = primaryAffiliateLink?.disclosure ?? undefined;
const photoUrl = getBreedPhotoUrl(breed);
const breedMediaAlt = `${breed.species === 'cat' ? 'Zdjęcie kota' : 'Zdjęcie rasy'} ${breed.name}`;

const heroStats = [
  ['Waga', formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')],
  ['Wysokość', formatRange(breed.height_min_cm, breed.height_max_cm, 'cm')],
  [
    'Długość życia',
    formatRange(
      breed.life_expectancy_min_years,
      breed.life_expectancy_max_years,
      'lat'
    ),
  ],
  ['Aktywność', formatActivityLevel(breed.activity_level)],
  ['Pielęgnacja', formatGroomingLevel(breed.grooming_level)],
  ['Szkolenie', formatTrainingDifficulty(breed.training_difficulty)],
];

const details = [
  ['Gatunek', formatSpecies(breed.species)],
  ['Waga', formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')],
  ['Wysokość', formatRange(breed.height_min_cm, breed.height_max_cm, 'cm')],
  [
    'Długość życia',
    formatRange(
      breed.life_expectancy_min_years,
      breed.life_expectancy_max_years,
      'lat'
    ),
  ],
  ['Aktywność', formatActivityLevel(breed.activity_level)],
  ['Pielęgnacja', formatGroomingLevel(breed.grooming_level)],
  ['Trudność szkolenia', formatTrainingDifficulty(breed.training_difficulty)],
  ['Dla rodziny', formatScore(breed.family_friendly_score)],
  ['Do mieszkania', formatScore(breed.apartment_score)],
  ['Dzienne kalorie', calories],
];

function getParagraphs(section: BreedContentSection): string[] {
  return section.body
    .split(/\r?\n+/)
    .map((paragraph) => paragraph.trim())
    .filter(Boolean);
}

function getRecognitionLabel(recognized: number, status: string | null): string {
  if (status === 'recognized') {
    return 'Uznana';
  }

  if (status === 'not_recognized') {
    return 'Brak na liście';
  }

  if (status === 'provisional') {
    return 'Uznana tymczasowo';
  }

  if (status === 'needs_verification') {
    return 'Do weryfikacji';
  }

  return recognized === 1 ? 'Uznana' : 'Brak na liście';
}

function getRecognitionStatusClass(recognized: number, status: string | null): string {
  if (status === 'recognized') {
    return 'registry-status--recognized';
  }

  if (status === 'not_recognized') {
    return 'registry-status--unrecognized';
  }

  if (status === 'provisional') {
    return 'registry-status--provisional';
  }

  if (status === 'needs_verification') {
    return 'registry-status--needs-verification';
  }

  return recognized === 1 ? 'registry-status--recognized' : 'registry-status--unrecognized';
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/rasy/${breed.slug}/`}
  ogType="article"
>
  <section class="breed-hero">
    <div class="container breed-hero__grid">
      <div class="breed-hero__content">
        <nav class="breadcrumbs" aria-label="Okruszki">
          <a href="/">Futrio</a> &gt; <a href="/rasy/">Rasy</a> &gt; {breed.name}
        </nav>
        <span class="badge">{formatSpecies(breed.species)}</span>
        <h1>{h1}</h1>
        <p class="lead">{breed.short_description ?? 'Opis rasy jest w przygotowaniu.'}</p>
        <div class="actions">
          <a class="button" href="#kalkulator-kalorii">Sprawdź kalkulator kalorii</a>
          <a class="button button--secondary" href="/poradniki/">Zobacz poradniki</a>
        </div>

        <dl class="hero-stats">
          {
            heroStats.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <aside class="breed-media" aria-label={breedMediaAlt}>
        {
          photoUrl ? (
            <figure class="breed-image breed-image--photo">
              <img
                src={photoUrl}
                alt={breedMediaAlt}
                title={breedMediaAlt}
                width="1200"
                height="800"
                loading="eager"
              />
            </figure>
          ) : (
            <div class="breed-hero-placeholder" aria-hidden="true">
              <span>{formatSpecies(breed.species)}</span>
              <strong>{breed.name}</strong>
            </div>
          )
        }
      </aside>
    </div>
  </section>

  <!-- TODO: Google AdSense placement - after hero -->

  <section class="section">
    <div class="container article-layout">
      <aside class="toc" aria-label="Spis treści">
        <h2>Spis treści</h2>
        <nav>
          <a href="#najwazniejsze-informacje">Najważniejsze informacje</a>
          <a href="#uznanie-rasy">Uznanie rasy</a>
          {
            sections.map((section) => (
              <a href={`#${section.section_key}`}>{section.heading}</a>
            ))
          }
          <a href="#faq">FAQ</a>
        </nav>
      </aside>

      <article class="breed-article">
        <section id="najwazniejsze-informacje" class="article-section">
          <h2>Najważniejsze informacje</h2>
          <dl class="info-grid info-grid--article">
            {
              details.map(([label, value]) => (
                <div class="info-item">
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))
            }
          </dl>
        </section>

        <section class="registry-section" id="uznanie-rasy">
          <div class="section-heading section-heading--split">
            <div>
              <p class="eyebrow">Metodologia ras</p>
              <h2>Uznanie rasy przez organizacje</h2>
            </div>
            <a class="text-link" href="/metodologia-ras/">Jak to sprawdzamy?</a>
          </div>
          <p>
            Różne organizacje kynologiczne i felinologiczne mogą uznawać różne rasy.
            Dlatego w Futrio pokazujemy status uznania osobno dla najważniejszych organizacji.
            Statusy weryfikujemy na podstawie oficjalnych list i standardów organizacji.
          </p>
          {allRecognitionsNeedVerification && (
            <div class="registry-note">
              Status uznania tej rasy wymaga jeszcze weryfikacji w oficjalnych źródłach.
            </div>
          )}
          <div class="registry-grid">
            {
              breed.registryRecognitions.map((recognition) => (
                <article class="registry-card">
                  <div>
                    <strong>{recognition.organizationCode}</strong>
                    <p>{recognition.organizationName}</p>
                  </div>
                  <span class:list={['registry-status', getRecognitionStatusClass(recognition.recognized, recognition.recognitionStatus)]}>
                    {getRecognitionLabel(recognition.recognized, recognition.recognitionStatus)}
                  </span>
                  {recognition.note && <p class="registry-card__note">{recognition.note}</p>}
                </article>
              ))
            }
          </div>
        </section>

        {
          sections.map((section) => (
            <>
              <section
                id={section.section_key}
                class:list={[
                  'article-section',
                  'content-section-card',
                  section.section_key === 'history' && 'breed-history',
                ]}
              >
                <h2>{section.heading}</h2>

                {getParagraphs(section).map((paragraph) => (
                  <p>{paragraph}</p>
                ))}

                {section.section_key === 'health' && (
                  <div class="health-disclaimer">
                    Informacje zdrowotne mają charakter orientacyjny i nie zastępują
                    konsultacji z lekarzem weterynarii.
                  </div>
                )}
              </section>

              {section.section_key === 'feeding' && (
                <>
                  <section class="calculator-inline-section" id="kalkulator-kalorii">
                    <div class="tool-card__header">
                      <p class="eyebrow">Żywienie w praktyce</p>
                      <h2>Kalkulator kalorii dla tej rasy</h2>
                      <p>
                        Wynik jest orientacyjny i zależy od masy ciała, wieku, aktywności
                        oraz stanu zdrowia zwierzęcia.
                      </p>
                    </div>
                    <CalorieCalculator
                      breedName={breed.name}
                      species={breed.species}
                      defaultWeightKg={calculatorWeightKg}
                      dailyCaloriesMin={calculatorDailyCaloriesMin}
                      dailyCaloriesMax={calculatorDailyCaloriesMax}
                      affiliateCtaLabel={affiliateCtaLabel}
                      affiliateCtaUrl={affiliateCtaUrl}
                      affiliateDisclosure={affiliateDisclosure}
                      client:visible
                    />
                  </section>

                  <section class="affiliate-placeholder">
                    <h2>Polecane produkty dla tej rasy</h2>
                    <p>
                      To miejsce jest przygotowane pod przyszłe, wyraźnie oznaczone
                      linki afiliacyjne. Na tym etapie pokazujemy wyłącznie placeholder.
                    </p>
                    {affiliateLinks.length > 0 ? (
                      <div class="affiliate-card-grid">
                        {affiliateLinks.map((link) => (
                          <article class="affiliate-card">
                            <h3>{link.anchor_text ?? link.label}</h3>
                            <p>
                              {link.description ??
                                'W przyszłości pokażemy tu produkty dopasowane do potrzeb tej rasy.'}
                            </p>
                            {link.url.includes('example.com') && (
                              <p class="affiliate-note">
                                Przykładowy placeholder - link zostanie podmieniony po wyborze programu afiliacyjnego.
                              </p>
                            )}
                            {link.disclosure && (
                              <p class="affiliate-disclosure">{link.disclosure}</p>
                            )}
                            <a class="button button--secondary" href={link.url} rel="nofollow sponsored">
                              {link.button_label ?? 'Zobacz polecane produkty'}
                            </a>
                          </article>
                        ))}
                      </div>
                    ) : (
                      <p>
                        W przyszłości pokażemy tu karmy, akcesoria i produkty dopasowane
                        do potrzeb tej rasy. Linki będą oznaczone jako afiliacyjne, jeśli
                        będą prowadzić do programu partnerskiego.
                      </p>
                    )}
                    <!-- TODO: Affiliate CTA based on D1 affiliate_links -->
                  </section>

                  <!-- TODO: Google AdSense placement - mid article -->
                </>
              )}

              {section.section_key === 'costs' && (
                <section class="calculator-inline-section" id="kalkulator-kosztow">
                  <div class="tool-card__header">
                    <p class="eyebrow">Budżet opiekuna</p>
                    <h2>Kalkulator kosztów utrzymania</h2>
                    <p>
                      Koszty są orientacyjne i zależą od jakości karmy, profilaktyki,
                      pielęgnacji oraz indywidualnych potrzeb zwierzęcia.
                    </p>
                  </div>
                  <CostCalculator
                    breedName={breed.name}
                    species={breed.species}
                    weightMinKg={calculatorWeightMinKg}
                    weightMaxKg={calculatorWeightMaxKg}
                    groomingLevel={calculatorGroomingLevel}
                    affiliateCtaLabel={affiliateCtaLabel}
                    affiliateCtaUrl={affiliateCtaUrl}
                    affiliateDisclosure={affiliateDisclosure}
                    client:visible
                  />
                </section>
              )}
            </>
          ))
        }

        {
          faqs.length > 0 && (
            <section class="breed-faq" id="faq">
              <div class="section-heading">
                <p class="eyebrow">Pytania opiekunów</p>
                <h2>FAQ</h2>
              </div>
              <div class="faq-grid">
                {
                  faqs.map((faq) => (
                    <article class="faq-item">
                      <h3>{faq.question}</h3>
                      <p>{faq.answer}</p>
                    </article>
                  ))
                }
              </div>
            </section>
          )
        }

        <section class="related-breeds">
          <h2>Zobacz też inne rasy</h2>
          <div class="breed-grid breed-grid--related">
            {
              relatedBreeds.map((relatedBreed) => (
                <BreedCard breed={relatedBreed} variant="related" />
              ))
            }
          </div>
        </section>

        <section class="article-section">
          <h2>Przydatne poradniki</h2>
          <div class="guide-grid guide-grid--compact">
            {
              usefulGuides.map((guide) => (
                guide && (
                  <GuideCard guide={guide} />
                )
              ))
            }
          </div>
        </section>

        <section class="article-section">
          <h2>Więcej tematów Futrio</h2>
          <div class="topic-links">
            <a href={speciesHub.href}>{speciesHub.label}</a>
            <a href="/zywienie/">Żywienie psa i kota</a>
            <a href="/koszty-utrzymania/">Koszty utrzymania</a>
            <a href="/pielegnacja/">Pielęgnacja psa i kota</a>
            <a href="/kalkulatory/">Kalkulatory Futrio</a>
          </div>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>
