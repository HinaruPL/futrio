---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  formatActivityLevel,
  formatGroomingLevel,
  formatRange,
  formatSpecies,
  getAllBreeds,
} from '../../lib/breeds-data';

const breeds = getAllBreeds();
const dogBreeds = breeds.filter((breed) => breed.species === 'dog');
const catBreeds = breeds.filter((breed) => breed.species === 'cat');

function hasRealImage(breed: (typeof breeds)[number]) {
  const imageUrl = breed.image?.image_url ?? '';

  return (
    Boolean(breed.image) &&
    breed.image?.image_source_type !== 'placeholder' &&
    (imageUrl.startsWith('https://') || imageUrl.startsWith('http://') || imageUrl.startsWith('/'))
  );
}
---

<BaseLayout
  title="Rasy psów i kotów - katalog Futrio"
  description="Przeglądaj rasy psów i kotów w Futrio. Sprawdź charakter, wagę, aktywność, pielęgnację, żywienie i orientacyjne koszty utrzymania."
  canonical="/rasy/"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Katalog ras</p>
      <h1>Rasy psów i kotów</h1>
      <p class="lead">
        Katalog Futrio pomaga porównać podstawowe cechy ras, ich potrzeby,
        aktywność, pielęgnację i orientacyjne koszty utrzymania.
      </p>
      <div class="hero-badges">
        <span class="badge">W bazie: {breeds.length} ras</span>
        <span class="badge">Psy: {dogBreeds.length}</span>
        <span class="badge">Koty: {catBreeds.length}</span>
      </div>
      <div class="actions">
        <a class="button" href="/psy/">Sekcja Psy</a>
        <a class="button button--secondary" href="/koty/">Sekcja Koty</a>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Linkowanie tematyczne</p>
        <h2>Sprawdź też praktyczne huby</h2>
      </div>
      <div class="topic-grid">
        <a class="topic-card topic-card--link" href="/koszty-utrzymania/">
          <span>Budżet</span>
          <strong>Koszty utrzymania</strong>
        </a>
        <a class="topic-card topic-card--link" href="/zywienie/">
          <span>Karma i kalorie</span>
          <strong>Żywienie psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/pielegnacja/">
          <span>Rutyna</span>
          <strong>Pielęgnacja psa i kota</strong>
        </a>
        <a class="topic-card topic-card--link" href="/kalkulatory/">
          <span>Narzędzia</span>
          <strong>Kalkulatory Futrio</strong>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Psy</p>
        <h2>Rasy psów</h2>
      </div>
      <div class="breed-grid grid">
        {
          dogBreeds.map((breed) => (
            <article class="card breed-card breed-card--catalog">
              {hasRealImage(breed) && breed.image ? (
                <img
                  class="breed-card__image"
                  src={breed.image.image_url}
                  alt={breed.image.image_alt}
                  loading="lazy"
                />
              ) : (
                <div class="mini-image-placeholder" aria-hidden="true">
                  <span>{formatSpecies(breed.species)}</span>
                </div>
              )}
              <div>
                <span class="badge">{formatSpecies(breed.species)}</span>
                <h3>{breed.name}</h3>
                <p>{breed.short_description ?? 'Opis rasy jest w przygotowaniu.'}</p>
              </div>
              <div class="breed-card__meta">
                <span>Waga: {formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')}</span>
                <span>Aktywność: {formatActivityLevel(breed.activity_level)}</span>
                <span>Pielęgnacja: {formatGroomingLevel(breed.grooming_level)}</span>
              </div>
              <a class="button button--secondary" href={`/rasy/${breed.slug}/`}>
                Zobacz opis rasy
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Koty</p>
        <h2>Rasy kotów</h2>
      </div>
      <div class="breed-grid grid">
        {
          catBreeds.map((breed) => (
            <article class="card breed-card breed-card--catalog">
              {hasRealImage(breed) && breed.image ? (
                <img
                  class="breed-card__image"
                  src={breed.image.image_url}
                  alt={breed.image.image_alt}
                  loading="lazy"
                />
              ) : (
                <div class="mini-image-placeholder" aria-hidden="true">
                  <span>{formatSpecies(breed.species)}</span>
                </div>
              )}
              <div>
                <span class="badge">{formatSpecies(breed.species)}</span>
                <h3>{breed.name}</h3>
                <p>{breed.short_description ?? 'Opis rasy jest w przygotowaniu.'}</p>
              </div>
              <div class="breed-card__meta">
                <span>Waga: {formatRange(breed.weight_min_kg, breed.weight_max_kg, 'kg')}</span>
                <span>Aktywność: {formatActivityLevel(breed.activity_level)}</span>
                <span>Pielęgnacja: {formatGroomingLevel(breed.grooming_level)}</span>
              </div>
              <a class="button button--secondary" href={`/rasy/${breed.slug}/`}>
                Zobacz opis rasy
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
