---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nie znaleziono strony | Futrio"
  description="Ta strona nie istnieje lub została przeniesiona. Wróć do strony głównej Futrio albo sprawdź bazę ras."
  canonical="/404/"
  ogType="website"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Błąd 404</p>
      <h1>Nie znaleziono strony</h1>
      <p class="lead">
        Ta strona nie istnieje albo została przeniesiona. Możesz wrócić do strony
        głównej Futrio lub przejść do bazy ras.
      </p>
      <div class="actions">
        <a class="button" href="/">Wróć na stronę główną</a>
        <a class="button button--secondary" href="/rasy/">Sprawdź bazę ras</a>
      </div>
    </div>
  </section>
</BaseLayout>
