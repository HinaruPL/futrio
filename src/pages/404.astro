---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nie znaleziono strony | Futrio"
  description="Ta strona nie istnieje lub została przeniesiona. Wróć do strony głównej Futrio albo sprawdź katalog ras, kalkulatory i poradniki."
  canonical="/404/"
  ogType="website"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Błąd 404</p>
      <h1>Nie znaleziono strony</h1>
      <p class="lead">
        Ta strona nie istnieje albo została przeniesiona. Możesz wrócić do strony
        głównej Futrio albo przejść do jednej z głównych sekcji portalu.
      </p>
      <div class="actions">
        <a class="button" href="/">Strona główna</a>
        <a class="button button--secondary" href="/rasy/">Rasy</a>
        <a class="button button--secondary" href="/kalkulatory/">Kalkulatory</a>
        <a class="button button--secondary" href="/poradniki/">Poradniki</a>
      </div>
    </div>
  </section>
</BaseLayout>
