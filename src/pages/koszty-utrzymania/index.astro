---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGuideBySlug } from '../../data/guides';
import { getAllBreeds } from '../../lib/breeds-data';

const guideSlugs = [
  'ile-kosztuje-utrzymanie-psa',
  'ile-kosztuje-utrzymanie-kota',
  'koszty-weterynarza-pies-kot',
  'wyprawka-dla-psa',
  'wyprawka-dla-kota',
];
const guides = guideSlugs.map((slug) => getGuideBySlug(slug)).filter(Boolean);
const budgetBreedSlugs = [
  'bernenski-pies-pasterski',
  'cane-corso',
  'labrador-retriever',
  'maine-coon',
  'kot-perski',
];
const budgetBreeds = getAllBreeds().filter((breed) => budgetBreedSlugs.includes(breed.slug));
---

<BaseLayout
  title="Koszty utrzymania psa i kota | Futrio"
  description="Sprawdź, co wpływa na koszty utrzymania psa lub kota: karma, weterynarz, pielęgnacja, akcesoria, wyprawka i nagłe wydatki."
  canonical="/koszty-utrzymania/"
>
  <section class="hero">
    <div class="container hero__content">
      <p class="eyebrow">Budżet opiekuna</p>
      <h1>Koszty utrzymania psa i kota</h1>
      <p class="lead">
        Koszt opieki zależy od wielkości zwierzęcia, karmy, profilaktyki, pielęgnacji,
        akcesoriów, nagłych wydatków, miasta i stylu opieki. Futrio pomaga policzyć
        budżet ostrożnie, bez obiecywania jednej uniwersalnej kwoty.
      </p>
      <div class="actions">
        <a class="button" href="/kalkulatory/">Przejdź do kalkulatorów</a>
        <a class="button button--secondary" href="/rasy/">Porównaj rasy</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Co wpływa na koszty?</p>
        <h2>Najważniejsze elementy budżetu</h2>
      </div>
      <div class="topic-grid">
        {
          [
            'Wielkość i masa zwierzęcia',
            'Rodzaj oraz jakość karmy',
            'Profilaktyka i wizyty weterynaryjne',
            'Pielęgnacja i ewentualny groomer',
            'Akcesoria, zabawki i wyprawka',
            'Nagłe wydatki oraz rezerwa',
            'Miasto i dostępność usług',
            'Styl opieki i aktywność',
          ].map((item) => (
            <article class="topic-card">
              <h3>{item}</h3>
              <p>Ten element może zmienić miesięczny budżet, dlatego warto uwzględnić go przed decyzją o rasie.</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Poradniki</p>
        <h2>Przeczytaj przed planowaniem budżetu</h2>
      </div>
      <div class="guide-grid">
        {
          guides.map((guide) => (
            guide && (
              <article class="guide-card">
                <span class="badge">{guide.categoryLabel}</span>
                <h3>{guide.title}</h3>
                <p>{guide.description}</p>
                <a class="text-link" href={`/poradniki/${guide.slug}/`}>Czytaj poradnik</a>
              </article>
            )
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <div class="section-heading">
        <p class="eyebrow">Rasy i budżet</p>
        <h2>Rasy, przy których warto szczególnie planować budżet</h2>
      </div>
      <div class="related-breeds__grid">
        {
          budgetBreeds.map((breed) => (
            <a href={`/rasy/${breed.slug}/`}>
              <span>{breed.species === 'dog' ? 'pies' : 'kot'}</span>
              <strong>{breed.name}</strong>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
